modules = ["python-3.11"]
[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Zeus Mastermind"

[[workflows.workflow]]
name = "Zeus Mastermind"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python zeusdl/zeus_mastermind.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8080
externalPort = 80
